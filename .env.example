# App
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Local PostgreSQL used by the dev container
DATABASE_URL=postgresql://cms:cms-dev-password@db:5432/cms?sslmode=disable
PGHOST=db
PGPORT=5432
PGDATABASE=cms
PGUSER=cms
PGPASSWORD=cms-dev-password

# Supabase placeholders for later integration work
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-me
SUPABASE_SERVICE_ROLE_KEY=replace-me

# External integrations used by the production app
STRIPE_SECRET_KEY=replace-me
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=replace-me
STRIPE_WEBHOOK_SECRET=replace-me
TWILIO_ACCOUNT_SID=replace-me
TWILIO_AUTH_TOKEN=replace-me
TWILIO_PHONE_NUMBER=replace-me
RESEND_API_KEY=replace-me