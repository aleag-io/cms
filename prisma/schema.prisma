generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  GLOBAL_ADMIN
  DIOCESE_ADMIN
  DIOCESE_STAFF
  DIOCESE_REPORT_VIEWER
  PARISH_ADMIN
  PARISH_STAFF
  PARISH_DATA_SHARING_MANAGER
  CLERGY
  MINISTRY_LEADER
  ORGANIZATION_LEADER
  PASTORAL_DATA_ACCESSOR
  MEMBER
}

enum OfficerType {
  CLERGY
  BOARD
  EXECUTIVE_COMMITTEE
  FINANCE_COMMITTEE
  TRUSTEE
  OTHER
}

enum EducationLevel {
  PRIMARY
  SECONDARY
  UNDERGRADUATE
  POSTGRADUATE
  OTHER
}

/// Directory-safe demographic gender (not pastoral-sensitive by itself).
enum Gender {
  MALE
  FEMALE
  OTHER
  UNSPECIFIED
}

enum RelationshipType {
  SPOUSE
  PARENT
  CHILD
  SIBLING
  GRANDPARENT
  GRANDCHILD
  IN_LAW
  OTHER
}

enum MembershipType {
  PRIMARY
  SECONDARY
}

enum DataCategory {
  MEMBER_DIRECTORY
  MEMBER_DEMOGRAPHICS_DETAIL
  FAMILY_RECORDS
  SACRAMENTAL_RECORDS
  GIVING_DETAIL
  GIVING_STATEMENTS
  PROGRAM_ROSTER
  FINANCIAL_STATEMENTS
  LEDGER_DETAIL
  ATTENDANCE_DETAIL
  AUDIT_LOG
  COMMUNICATIONS_HISTORY
}

enum GranteeType {
  DIOCESE
  PARISH
}

enum SharingScope {
  ALL_RECORDS
  SUMMARY_ONLY
  PROGRAM_SCOPED
  PERIOD_SCOPED
}

enum SharingRequestStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

enum ShareMode {
  USER_SHARE
  ROLE_SHARE
  SECURE_LINK
}

enum PermissionResource {
  MEMBER_PROFILE
  MEMBER_PRIVATE_NOTE
  MEMBER_PASTORAL_DATA
  MEMBER_SACRAMENTAL_RECORD
  PARISH_DIRECTORY
  MEMBER_EXPORT
  PARISH_OFFICER
  PARISH_PERMISSION_OVERRIDE
  FINANCE_LEDGER
  FINANCE_APPROVAL
  FINANCE_GIVING
  REPORT
  MEMBER_IMPORT
}

// ── R5 / M10: Finance & Giving ───────────────────────────────────────────────

/// Ledger books can be owned at four operational levels:
/// - DIOCESE: diocese general ledger (ownerId = dioceseId)
/// - PARISH: parish/church general ledger (ownerId = parishId)
/// - ORGANIZATION: org ledger (ownerId = organizationId); org may be
///   diocese-scoped (Organization.parishId null) or parish-scoped
enum LedgerOwnerType {
  DIOCESE
  PARISH
  ORGANIZATION
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  INCOME
  EXPENSE
}

enum JournalDirection {
  DEBIT
  CREDIT
}

enum JournalStatus {
  DRAFT
  PENDING_APPROVAL
  POSTED
  VOID
}

enum PeriodStatus {
  OPEN
  CLOSED
}

enum JournalSource {
  MANUAL
  DONATION
  STRIPE
  VENDOR_BILL
  PAYMENT
  REVERSAL
  BATCH_ADJUSTMENT
}

enum ApprovalMode {
  STRICT
  THRESHOLD_BASED
  HYBRID
}

enum ApprovalEntityKind {
  JOURNAL
  VENDOR_BILL
  PAYMENT
}

enum ApprovalRequestStatus {
  PENDING
  APPROVED
  REJECTED
  AUTO_APPROVED
}

enum ApprovalDecisionType {
  APPROVE
  REJECT
}

enum DonationMethod {
  CASH
  CHECK
  ZELLE
  ACH
  CARD
  STOCK
  OTHER
}

enum DonationStatus {
  ACTIVE
  VOID
}

enum DonationBatchStatus {
  OPEN
  POSTED
  VOID
}

enum CampaignStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum PledgeStatus {
  ACTIVE
  FULFILLED
  LAPSED
  CANCELLED
}

enum PledgeFrequency {
  ONE_TIME
  WEEKLY
  MONTHLY
  ANNUAL
}

enum VendorBillStatus {
  DRAFT
  SUBMITTED
  APPROVED
  POSTED
  PAID
  VOID
}

enum PaymentMethod {
  CASH
  CHECK
  ACH
  ONLINE
  OTHER
}

enum BudgetStatus {
  DRAFT
  APPROVED
  LOCKED
  ARCHIVED
}

enum BankLineStatus {
  UNMATCHED
  MATCHED
  IGNORED
}

enum ReconciliationRunStatus {
  OPEN
  COMPLETED
}

enum GivingStatementRecipientType {
  FAMILY
  MEMBER
  EXTERNAL_DONOR
}

enum GivingStatementPeriodType {
  ANNUAL
  QUARTERLY
}

enum GivingStatementStatus {
  GENERATED
  SENT
  FAILED
}

/// Seven sacramental record types of the Mar Thoma Church (PA-7).
enum SacramentType {
  BAPTISM
  HOLY_COMMUNION
  CONFIRMATION
  CONFESSION
  MARRIAGE
  ORDINATION
  ANOINTING_OF_THE_SICK
}

enum ObservanceType {
  FEAST
  HOLY_DAY
  SEASON_START
  SEASON_END
  DIOCESAN_EVENT
  OTHER
}

enum PermissionAction {
  READ
  WRITE
  DELETE
  EXPORT
  SEND
}

enum MemberStatus {
  PENDING
  ACTIVE
  INACTIVE
  DECEASED
  MOVED
}

// ── Phase 3: Parish operations enums ─────────────────────────────────────────

enum ProgramType {
  FAITH_FORMATION
  BIBLE_STUDY
  YOUTH
  CHOIR
  OUTREACH
  OTHER
}

enum EnrollmentRole {
  PARTICIPANT
  FACILITATOR
  COORDINATOR
}

enum EnrollmentStatus {
  PENDING
  ACTIVE
  COMPLETED
  WITHDRAWN
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  EXCUSED
}

enum OrganizationType {
  PRAYER_GROUP
  COMMITTEE
  AUXILIARY
  MINISTRY
  OTHER
}

enum MembershipMode {
  OPEN
  EXCLUSIVE
}

enum OrgMembershipRole {
  MEMBER
  OFFICER
  LEADER
}

enum EventType {
  SERVICE
  MEETING
  SOCIAL
  OUTREACH
  OTHER
}

enum RsvpStatus {
