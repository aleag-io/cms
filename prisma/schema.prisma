model Diocese {
  id        String       @id @default(uuid()) @db.Uuid
  name      String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  parishes  Parish[]
  users     AppUser[]
  audits    AuditEntry[]
  sharingRequests       DataSharingRequest[]
  sharingGrants         DataSharingGrant[]
  emergencyAccessGrants EmergencyAccessGrant[]
  contextualShares      ContextualShare[]
  liturgicalObservances LiturgicalObservance[]
  // R5 finance (diocese-owned ledgers + diocese-scoped rows)
  funds                    Fund[]
  accounts                 Account[]
  accountingPeriods        AccountingPeriod[]
  journalEntries           JournalEntry[]
  approvalPolicies         ApprovalPolicy[]
  approvalRequests         ApprovalRequest[]
  externalDonors           ExternalDonor[]
  campaigns                Campaign[]
  donations                Donation[]
  donationBatches          DonationBatch[]
  pledges                  Pledge[]
  vendors                  Vendor[]
  vendorBills              VendorBill[]
  payments                 Payment[]
  budgets                  Budget[]
  bankStatementLines       BankStatementLine[]
  reconciliationRuns       ReconciliationRun[]
  givingStatements         GivingStatement[]
  givingCategories         GivingCategory[]
  stripeEvents             StripeEvent[]
  organizations            Organization[] @relation("DioceseOrganizations")
  // R6 integrations
  webhookSubscriptions     WebhookSubscription[]
  webhookEvents            WebhookEvent[]
  webhookDeliveries        WebhookDelivery[]
}

model Parish {
  id        String   @id @default(uuid()) @db.Uuid
  dioceseId String   @db.Uuid
  name      String
  address   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Configurable family-number scheme (MM-10)
  // familyNumberPrefix: alphabetic prefix, e.g. "PAR-" or "" for none
  // familyNumberWidth:  total digit width, zero-padded, e.g. 4 → "0042"
  // familyNumberStart:  first sequence value, e.g. 1 or 100
  familyNumberPrefix String @default("")
  familyNumberWidth  Int    @default(4)
  familyNumberStart  Int    @default(1)

  // Member self-registration: auto-approve PENDING intakes (MM-8)
  autoApprove Boolean @default(false)

  diocese                  Diocese                    @relation(fields: [dioceseId], references: [id], onDelete: Cascade)
  users                    AppUser[]
  families                 Family[]
  members                  Member[]
  officers                 ParishOfficer[]
  memberParishes           MemberParish[]
  privateNotes             MemberPrivateNote[]
  memberPastoralData       MemberPastoralData[]
  familyPastoralData       FamilyPastoralData[]
  sacramentalRecords       SacramentalRecord[]
  permissionOverrides      ParishPermissionOverride[]
  memberRelationships      MemberRelationship[]
  programs                 Program[]
  programEnrollments       ProgramEnrollment[]
  programSessions          ProgramSession[]
  programSessionAttendance ProgramSessionAttendance[]
  organizations            Organization[]
  organizationMemberships  OrganizationMembership[]
  organizationOfficers     OrganizationOfficer[]
  events                   Event[]
  eventAttendances         EventAttendance[]
  facilities               Facility[]
  facilityBookings         FacilityBooking[]
  messages                 Message[]
  messageRecipients        MessageRecipient[]
  messageTemplates         MessageTemplate[]
  communicationPreferences CommunicationPreference[]
  volunteerAssignments     VolunteerAssignment[]
  memberRegistrations      MemberRegistration[]
  audits                   AuditEntry[]
  sharingRequests          DataSharingRequest[]
  sharingGrants            DataSharingGrant[]
  emergencyAccessGrants    EmergencyAccessGrant[]
  contextualShares         ContextualShare[]
  liturgicalObservances    LiturgicalObservance[]
  // R5 finance
  funds                    Fund[]
  accounts                 Account[]
  accountingPeriods        AccountingPeriod[]
  journalEntries           JournalEntry[]
  approvalPolicies         ApprovalPolicy[]
  approvalRequests         ApprovalRequest[]
  externalDonors           ExternalDonor[]
  campaigns                Campaign[]
  donations                Donation[]
  donationBatches          DonationBatch[]
  pledges                  Pledge[]
  vendors                  Vendor[]
  vendorBills              VendorBill[]
  payments                 Payment[]
  budgets                  Budget[]
  bankStatementLines       BankStatementLine[]
  reconciliationRuns       ReconciliationRun[]
  givingStatements         GivingStatement[]
  givingCategories         GivingCategory[]
  stripeEvents             StripeEvent[]
  // R6 integrations
  webhookSubscriptions     WebhookSubscription[]
  webhookEvents            WebhookEvent[]
  webhookDeliveries        WebhookDelivery[]

  @@index([dioceseId])
}

model AppUser {
  id                         String                     @id @default(uuid()) @db.Uuid
  email                      String                     @unique
  displayName                String
  role                       Role
  dioceseId                  String                     @db.Uuid
  parishId                   String?                    @db.Uuid
  isActive                   Boolean                    @default(true)
  createdAt                  DateTime                   @default(now())
  updatedAt                  DateTime                   @updatedAt
  diocese                    Diocese                    @relation(fields: [dioceseId], references: [id], onDelete: Cascade)
  parish                     Parish?                    @relation(fields: [parishId], references: [id], onDelete: SetNull)
  memberProfile              Member?                    @relation("AppUserMember")
  grantedPermissionOverrides ParishPermissionOverride[] @relation("ParishPermissionOverrideGrantedBy")
  audits                     AuditEntry[]               @relation("AuditActor")
  requestedSharingRequests   DataSharingRequest[]       @relation("SharingRequestRequestedBy")
  reviewedSharingRequests    DataSharingRequest[]       @relation("SharingRequestReviewedBy")
  grantedSharingGrants       DataSharingGrant[]         @relation("SharingGrantGrantedBy")
  revokedSharingGrants       DataSharingGrant[]         @relation("SharingGrantRevokedBy")
  grantedEmergencyAccess     EmergencyAccessGrant[]     @relation("EmergencyAccessGrantedBy")
  revokedEmergencyAccess     EmergencyAccessGrant[]     @relation("EmergencyAccessRevokedBy")
  createdContextualShares    ContextualShare[]          @relation("ContextualShareCreatedBy")
  recipientContextualShares  ContextualShare[]          @relation("ContextualShareRecipient")
  revokedContextualShares    ContextualShare[]          @relation("ContextualShareRevokedBy")
  createdSacramentalRecords  SacramentalRecord[]         @relation("SacramentalRecordCreatedBy")
  // R5 finance
  createdJournalEntries      JournalEntry[]             @relation("JournalEntryCreatedBy")
  postedJournalEntries       JournalEntry[]             @relation("JournalEntryPostedBy")
  closedAccountingPeriods    AccountingPeriod[]         @relation("PeriodClosedBy")
  reopenedAccountingPeriods  AccountingPeriod[]         @relation("PeriodReopenedBy")
  approvalRequestsAsMaker    ApprovalRequest[]          @relation("ApprovalRequestMaker")
  approvalDecisions          ApprovalDecision[]         @relation("ApprovalDecisionApprover")
  generatedGivingStatements  GivingStatement[]          @relation("GivingStatementGeneratedBy")
  createdWebhookSubscriptions WebhookSubscription[]     @relation("WebhookSubscriptionCreatedBy")

  @@index([dioceseId, role])
  @@index([parishId, role])
}

model Family {
  id                  String              @id @default(uuid()) @db.Uuid
  dioceseId           String              @db.Uuid
  parishId            String              @db.Uuid
  familyNumber        String
  familyName          String
  primaryContactEmail String?
  primaryContactPhone String?
  address             String?
  registrationDate    DateTime            @default(now())
  isActive            Boolean             @default(true)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  parish              Parish              @relation(fields: [parishId], references: [id], onDelete: Cascade)
  members             Member[]
  pastoralData        FamilyPastoralData?
  /// Giving envelope number unique per parish (R5)
  envelopeNumber      String?
  donations           Donation[]
  pledges             Pledge[]
  givingStatements    GivingStatement[]
  externalDonorsLinked ExternalDonor[]    @relation("ExternalDonorLinkedFamily")

  @@unique([parishId, familyNumber])
  @@unique([parishId, envelopeNumber])
  @@index([dioceseId, parishId])
}

model Member {
  id                       String                     @id @default(uuid()) @db.Uuid
  dioceseId                String                     @db.Uuid
  parishId                 String                     @db.Uuid
  familyId                 String?                    @db.Uuid
  // Linked Supabase/AppUser for self-service access (staged for Phase 3)
  userId                   String?                    @unique @db.Uuid
  memberIdentifier         String
  firstName                String
  lastName                 String
  email                    String?
  phone                    String?
  gender                   Gender?
  workNotes                String?
  educationLevel           EducationLevel?
  skillsInterests          String[]                   @default([])
  status                   MemberStatus               @default(ACTIVE)
  // Transfer stub — full workflow in Phase 4
  transferredFromParishId  String?                    @db.Uuid
  transferredAt            DateTime?
  createdAt                DateTime                   @default(now())
  updatedAt                DateTime                   @updatedAt
  parish                   Parish                     @relation(fields: [parishId], references: [id], onDelete: Cascade)
  family                   Family?                    @relation(fields: [familyId], references: [id], onDelete: SetNull)
  user                     AppUser?                   @relation("AppUserMember", fields: [userId], references: [id], onDelete: SetNull)
  officerAssignments       ParishOfficer[]
  privateNote              MemberPrivateNote?
  pastoralData             MemberPastoralData?
  sacramentalRecords       SacramentalRecord[]        @relation("SacramentalRecordSubject")
  spouseOfSacramental      SacramentalRecord[]        @relation("SacramentalRecordSpouse")
  memberParishes           MemberParish[]
  relatedTo                MemberRelationship[]       @relation("MemberRelationshipFrom")
  relatedFrom              MemberRelationship[]       @relation("MemberRelationshipTo")
  coordinatedPrograms      Program[]                  @relation("ProgramCoordinator")
  programEnrollments       ProgramEnrollment[]
  sessionAttendances       ProgramSessionAttendance[]
  organizationMemberships  OrganizationMembership[]
  organizationOfficerRoles OrganizationOfficer[]
  eventAttendances         EventAttendance[]
  messageRecipients        MessageRecipient[]
  communicationPreferences CommunicationPreference[]
  volunteerAssignments     VolunteerAssignment[]
  registration             MemberRegistration?        @relation("MemberRegistrationApproved")
  donations                Donation[]
  pledges                  Pledge[]
  givingStatements         GivingStatement[]

  @@unique([parishId, memberIdentifier])
  @@index([dioceseId, parishId, status])
}

model ParishOfficer {
  id          String      @id @default(uuid()) @db.Uuid
  parishId    String      @db.Uuid
  memberId    String      @db.Uuid
  title       String
  officerType OfficerType
  termStart   DateTime    @default(now())
  termEnd     DateTime?
  isActive    Boolean     @default(true)
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  parish      Parish      @relation(fields: [parishId], references: [id], onDelete: Cascade)
  member      Member      @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([parishId, officerType, isActive])
  @@index([memberId, officerType])
}

model MemberPrivateNote {
  id        String   @id @default(uuid()) @db.Uuid
  memberId  String   @unique @db.Uuid
  parishId  String   @db.Uuid
  note      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  parish    Parish   @relation(fields: [parishId], references: [id], onDelete: Cascade)

  @@index([parishId])
}

model MemberPastoralData {
  id              String    @id @default(uuid()) @db.Uuid
  memberId        String    @unique @db.Uuid
  parishId        String    @db.Uuid
  dateOfBirth     DateTime?
  baptismDate     DateTime?
  chrismationDate DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  member          Member    @relation(fields: [memberId], references: [id], onDelete: Cascade)
  parish          Parish    @relation(fields: [parishId], references: [id], onDelete: Cascade)

  @@index([parishId])
}

model FamilyPastoralData {
  id              String    @id @default(uuid()) @db.Uuid
  familyId        String    @unique @db.Uuid
  parishId        String    @db.Uuid
  anniversaryDate DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  family          Family    @relation(fields: [familyId], references: [id], onDelete: Cascade)
  parish          Parish    @relation(fields: [parishId], references: [id], onDelete: Cascade)

  @@index([parishId])
}

/// Full sacramental register row (R4 / M8). Pastoral dates on MemberPastoralData
/// remain summary fields; this table is the official register.
model SacramentalRecord {
  id               String        @id @default(uuid()) @db.Uuid
  parishId         String        @db.Uuid
  memberId         String        @db.Uuid
  sacramentType    SacramentType
  occurredOn       DateTime      @db.Date
  officiantName    String?
  locationText     String?
  registerBook     String?
  registerPage     String?
  registerEntry    String?
  notes            String?
  /// Godparents / sponsors (baptism, confirmation).
  sponsorNames     String?
  /// In-parish spouse when known (marriage).
  spouseMemberId   String?       @db.Uuid
  /// Free-text spouse when not linked to a Member.
  spouseName       String?
  witnessNames     String?
  ordainedOffice   String?
  /// Confession: reference only — never confession content.
  pastoralNoteRef  String?
  isActive         Boolean       @default(true)
  createdByUserId  String?       @db.Uuid
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  parish           Parish        @relation(fields: [parishId], references: [id], onDelete: Cascade)
  member           Member        @relation("SacramentalRecordSubject", fields: [memberId], references: [id], onDelete: Cascade)
  spouseMember     Member?       @relation("SacramentalRecordSpouse", fields: [spouseMemberId], references: [id], onDelete: SetNull)
  createdBy        AppUser?      @relation("SacramentalRecordCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([parishId, sacramentType, occurredOn])
  @@index([memberId, sacramentType])
  @@index([parishId, isActive])
}

/// Diocese-published or parish-local liturgical observance (R4 / M9).
/// parishId NULL = diocese-wide entry; non-null = parish-local only.
model LiturgicalObservance {
  id             String         @id @default(uuid()) @db.Uuid
  dioceseId      String         @db.Uuid
  parishId       String?        @db.Uuid
  title          String
  observanceType ObservanceType @default(FEAST)
  /// Annual recurrence month (1–12). Prefer over RRULE for v1 feasts.
  month          Int?
  /// Annual recurrence day of month (1–31).
  day            Int?
  /// One-off or season date (optional when month/day set).
  occursOn       DateTime?      @db.Date
  endsOn         DateTime?      @db.Date
  lectionaryRef  String?
  isPublished    Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  diocese        Diocese        @relation(fields: [dioceseId], references: [id], onDelete: Cascade)
  parish         Parish?        @relation(fields: [parishId], references: [id], onDelete: Cascade)

  @@index([dioceseId, isPublished])
  @@index([parishId, occursOn])
  @@index([dioceseId, month, day])
}

model MemberRelationship {
  id               String           @id @default(uuid()) @db.Uuid
  parishId         String           @db.Uuid
  memberId         String           @db.Uuid
  relatedMemberId  String           @db.Uuid
  relationshipType RelationshipType
  notes            String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  parish           Parish           @relation(fields: [parishId], references: [id], onDelete: Cascade)
  member           Member           @relation("MemberRelationshipFrom", fields: [memberId], references: [id], onDelete: Cascade)
  relatedMember    Member           @relation("MemberRelationshipTo", fields: [relatedMemberId], references: [id], onDelete: Cascade)

  @@unique([memberId, relatedMemberId, relationshipType])
  @@index([parishId])
}

model MemberParish {
  id             String         @id @default(uuid()) @db.Uuid
  memberId       String         @db.Uuid
  parishId       String         @db.Uuid
  isPrimary      Boolean        @default(false)
  membershipType MembershipType @default(PRIMARY)
  joinedAt       DateTime       @default(now())
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  member         Member         @relation(fields: [memberId], references: [id], onDelete: Cascade)
  parish         Parish         @relation(fields: [parishId], references: [id], onDelete: Cascade)

  @@unique([memberId, parishId])
  @@index([parishId, isPrimary])
}

model ParishPermissionOverride {
  id              String             @id @default(uuid()) @db.Uuid
  parishId        String             @db.Uuid
  role            Role
  resource        PermissionResource
  action          PermissionAction
  isAllowed       Boolean
  grantedByUserId String             @db.Uuid
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  parish          Parish             @relation(fields: [parishId], references: [id], onDelete: Cascade)
  grantedBy       AppUser            @relation("ParishPermissionOverrideGrantedBy", fields: [grantedByUserId], references: [id], onDelete: Restrict)

  @@unique([parishId, role, resource, action])
  @@index([parishId])
}

model AuditEntry {
  id          String       @id @default(uuid()) @db.Uuid
  requestId   String
  timestamp   DateTime     @default(now())
  actorType   ActorType
  actorUserId String?      @db.Uuid
  actorLabel  String
  action      String
  entityType  String
  entityId    String?
  outcome     AuditOutcome
  dioceseId   String?      @db.Uuid
  parishId    String?      @db.Uuid
  metadata    Json?
  actorUser   AppUser?     @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  diocese     Diocese?     @relation(fields: [dioceseId], references: [id], onDelete: SetNull)
  parish      Parish?      @relation(fields: [parishId], references: [id], onDelete: SetNull)

  @@index([timestamp])
  @@index([dioceseId, parishId, action])
}

// ── Phase 4: Data-sharing governance ─────────────────────────────────────────

model DataSharingRequest {
  id                String               @id @default(uuid()) @db.Uuid
  parishId          String               @db.Uuid
  dioceseId         String               @db.Uuid
  dataCategory      DataCategory
  reason            String
  status            SharingRequestStatus @default(PENDING)
  requestedByUserId String               @db.Uuid
  reviewedByUserId  String?              @db.Uuid
  reviewedAt        DateTime?
  expiresAt         DateTime
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  parish            Parish               @relation(fields: [parishId], references: [id], onDelete: Cascade)
  diocese           Diocese              @relation(fields: [dioceseId], references: [id], onDelete: Cascade)
  requestedBy       AppUser              @relation("SharingRequestRequestedBy", fields: [requestedByUserId], references: [id], onDelete: Restrict)
  reviewedBy        AppUser?             @relation("SharingRequestReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  grant             DataSharingGrant?

  @@index([parishId, status])
  @@index([dioceseId, status])
  @@index([expiresAt])
}

model DataSharingGrant {
  id               String          @id @default(uuid()) @db.Uuid
  parishId         String          @db.Uuid
  dioceseId        String          @db.Uuid
  dataCategory     DataCategory
  granteeType      GranteeType     @default(DIOCESE)
  granteeId        String          @db.Uuid
  granteeRoleFilter Role?
  scope            SharingScope    @default(ALL_RECORDS)
  scopeDetail      Json?
  grantedByUserId  String          @db.Uuid
  requestId        String?         @unique @db.Uuid
  grantedAt        DateTime        @default(now())
  expiresAt        DateTime?
  isActive         Boolean         @default(true)
  revokedAt        DateTime?
  revokedByUserId  String?         @db.Uuid
  notes            String?
  parish           Parish          @relation(fields: [parishId], references: [id], onDelete: Cascade)
  diocese          Diocese         @relation(fields: [dioceseId], references: [id], onDelete: Cascade)
  grantedBy        AppUser         @relation("SharingGrantGrantedBy", fields: [grantedByUserId], references: [id], onDelete: Restrict)
  request          DataSharingRequest? @relation(fields: [requestId], references: [id], onDelete: SetNull)
  revokedBy        AppUser?        @relation("SharingGrantRevokedBy", fields: [revokedByUserId], references: [id], onDelete: SetNull)

  @@index([parishId, dataCategory, isActive])
  @@index([dioceseId, granteeId, isActive])
  @@index([expiresAt])
}

model EmergencyAccessGrant {
  id              String    @id @default(uuid()) @db.Uuid
  parishId        String    @db.Uuid
  dioceseId       String    @db.Uuid
  grantedByUserId String    @db.Uuid
  justification   String
  grantedAt       DateTime  @default(now())
  expiresAt       DateTime
  isActive        Boolean   @default(true)
  revokedAt       DateTime?
  revokedByUserId String?   @db.Uuid
  parish          Parish    @relation(fields: [parishId], references: [id], onDelete: Cascade)
  diocese         Diocese   @relation(fields: [dioceseId], references: [id], onDelete: Cascade)
  grantedBy       AppUser   @relation("EmergencyAccessGrantedBy", fields: [grantedByUserId], references: [id], onDelete: Restrict)
  revokedBy       AppUser?  @relation("EmergencyAccessRevokedBy", fields: [revokedByUserId], references: [id], onDelete: SetNull)

  @@index([parishId, isActive])
  @@index([dioceseId, isActive])
  @@index([expiresAt])
}

model ContextualShare {
  id              String    @id @default(uuid()) @db.Uuid
  parishId        String    @db.Uuid
  dioceseId       String    @db.Uuid
  resourceType    String
  resourceId      String?
  shareMode       ShareMode
  createdByUserId String    @db.Uuid
  recipientUserId String?   @db.Uuid
  recipientRole   Role?
  tokenHash       String?   @unique
  isAnonymized    Boolean   @default(false)
  expiresAt       DateTime?
  maxViews        Int?
  viewCount       Int       @default(0)
  isActive        Boolean   @default(true)
  revokedAt       DateTime?
  revokedByUserId String?   @db.Uuid
  createdAt       DateTime  @default(now())
  parish          Parish    @relation(fields: [parishId], references: [id], onDelete: Cascade)
  diocese         Diocese   @relation(fields: [dioceseId], references: [id], onDelete: Cascade)
  createdBy       AppUser   @relation("ContextualShareCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  recipientUser   AppUser?  @relation("ContextualShareRecipient", fields: [recipientUserId], references: [id], onDelete: SetNull)
  revokedBy       AppUser?  @relation("ContextualShareRevokedBy", fields: [revokedByUserId], references: [id], onDelete: SetNull)

  @@index([parishId, resourceType, isActive])
  @@index([dioceseId, isActive])
  @@index([expiresAt])
}

// ── Phase 3: Programs & ministries (PA-3, MM-3/4) ────────────────────────────

model Program {
  id                   String                @id @default(uuid()) @db.Uuid
  dioceseId            String                @db.Uuid
  parishId             String                @db.Uuid
  name                 String
  description          String?
  programType          ProgramType           @default(OTHER)
  coordinatorMemberId  String?               @db.Uuid
  isActive             Boolean               @default(true)
  startDate            DateTime?
  endDate              DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  parish               Parish                @relation(fields: [parishId], references: [id], onDelete: Cascade)
  coordinator          Member?               @relation("ProgramCoordinator", fields: [coordinatorMemberId], references: [id], onDelete: SetNull)
  enrollments          ProgramEnrollment[]
  sessions             ProgramSession[]
  volunteerAssignments VolunteerAssignment[]

  @@index([dioceseId, parishId, isActive])
  @@index([coordinatorMemberId])
}

model ProgramEnrollment {
  id         String           @id @default(uuid()) @db.Uuid
  dioceseId  String           @db.Uuid
  parishId   String           @db.Uuid
  programId  String           @db.Uuid
  memberId   String           @db.Uuid
  role       EnrollmentRole   @default(PARTICIPANT)
  status     EnrollmentStatus @default(ACTIVE)
  enrolledAt DateTime         @default(now())
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  parish     Parish           @relation(fields: [parishId], references: [id], onDelete: Cascade)
  program    Program          @relation(fields: [programId], references: [id], onDelete: Cascade)
  member     Member           @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([programId, memberId])
  @@index([dioceseId, parishId])
  @@index([memberId, role])
}

model ProgramSession {
  id          String                     @id @default(uuid()) @db.Uuid
  dioceseId   String                     @db.Uuid
  parishId    String                     @db.Uuid
  programId   String                     @db.Uuid
  title       String
  scheduledAt DateTime
  location    String?
  createdAt   DateTime                   @default(now())
  updatedAt   DateTime                   @updatedAt
  parish      Parish                     @relation(fields: [parishId], references: [id], onDelete: Cascade)
  program     Program                    @relation(fields: [programId], references: [id], onDelete: Cascade)
  attendance  ProgramSessionAttendance[]

  @@index([dioceseId, parishId])
  @@index([programId, scheduledAt])
}

model ProgramSessionAttendance {
  id        String           @id @default(uuid()) @db.Uuid
  dioceseId String           @db.Uuid
  parishId  String           @db.Uuid
  sessionId String           @db.Uuid
  memberId  String           @db.Uuid
  status    AttendanceStatus @default(PRESENT)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  parish    Parish           @relation(fields: [parishId], references: [id], onDelete: Cascade)
  session   ProgramSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  member    Member           @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([sessionId, memberId])
  @@index([dioceseId, parishId])
}

// ── Phase 3: Organizations (PA-14/15/16) ─────────────────────────────────────

model Organization {
  id                   String                   @id @default(uuid()) @db.Uuid
  dioceseId            String                   @db.Uuid
  /// Null = diocese-level organization; set = parish-level organization
  parishId             String?                  @db.Uuid
  name                 String
  description          String?
  organizationType     OrganizationType         @default(OTHER)
  membershipMode       MembershipMode           @default(OPEN)
  hasOwnLedger         Boolean                  @default(false)
  isActive             Boolean                  @default(true)
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt
  diocese              Diocese                  @relation("DioceseOrganizations", fields: [dioceseId], references: [id], onDelete: Cascade)
  parish               Parish?                  @relation(fields: [parishId], references: [id], onDelete: Cascade)
  memberships          OrganizationMembership[]
  officers             OrganizationOfficer[]
  volunteerAssignments VolunteerAssignment[]

  @@index([dioceseId, parishId, isActive])
  @@index([parishId, organizationType])
  @@index([dioceseId, isActive])
}

// Note: Organization ledger rows use polymorphic ownerId (no FK to Organization)
// because ownerType is DIOCESE | PARISH | ORGANIZATION.

model OrganizationMembership {
  id               String            @id @default(uuid()) @db.Uuid
  dioceseId        String            @db.Uuid
  /// Null when parent organization is diocese-scoped
  parishId         String?           @db.Uuid
  organizationId   String            @db.Uuid
  memberId         String            @db.Uuid
  role             OrgMembershipRole @default(MEMBER)
  joinedAt         DateTime          @default(now())
  leftAt           DateTime?
  // Denormalized from parent Organization for the PA-16 partial unique index.
  // Kept in sync by the org_membership_propagate trigger (Supabase SQL).
  organizationType OrganizationType
  membershipMode   MembershipMode
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  parish           Parish?           @relation(fields: [parishId], references: [id], onDelete: Cascade)
  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  member           Member            @relation(fields: [memberId], references: [id], onDelete: Cascade)
  // Note: the PA-16 exclusivity partial unique index is declared in Supabase SQL
  // (org_membership_exclusive_active) — it cannot be expressed in Prisma.

  @@index([dioceseId, parishId])
  @@index([organizationId])
  @@index([memberId])
}

model OrganizationOfficer {
  id             String       @id @default(uuid()) @db.Uuid
  dioceseId      String       @db.Uuid
  /// Null when parent organization is diocese-scoped
  parishId       String?      @db.Uuid
  organizationId String       @db.Uuid
  memberId       String       @db.Uuid
  title          String
  isActive       Boolean      @default(true)
  termStart      DateTime     @default(now())
  termEnd        DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  parish         Parish?      @relation(fields: [parishId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  member         Member       @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([dioceseId, parishId])
  @@index([organizationId, isActive])
  @@index([memberId])
}

// ── Phase 3: Events & facilities (PA-4/5, MM-4) ──────────────────────────────

model Event {
  id                   String                @id @default(uuid()) @db.Uuid
  dioceseId            String                @db.Uuid
  parishId             String                @db.Uuid
  name                 String
  description          String?
  eventType            EventType             @default(OTHER)
  startAt              DateTime
  endAt                DateTime
  recurrenceRule       String?
  maxCapacity          Int?
  facilityId           String?               @db.Uuid
  isPublic             Boolean               @default(true)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  parish               Parish                @relation(fields: [parishId], references: [id], onDelete: Cascade)
  facility             Facility?             @relation(fields: [facilityId], references: [id], onDelete: SetNull)
  attendance           EventAttendance[]
  bookings             FacilityBooking[]
  volunteerAssignments VolunteerAssignment[]

  @@index([dioceseId, parishId, startAt])
  @@index([facilityId])
}

model EventAttendance {
  id         String     @id @default(uuid()) @db.Uuid
  dioceseId  String     @db.Uuid
  parishId   String     @db.Uuid
  eventId    String     @db.Uuid
  memberId   String     @db.Uuid
  rsvpStatus RsvpStatus @default(YES)
  attended   Boolean    @default(false)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  parish     Parish     @relation(fields: [parishId], references: [id], onDelete: Cascade)
  event      Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  member     Member     @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([eventId, memberId])
  @@index([dioceseId, parishId])
}

model Facility {
  id        String            @id @default(uuid()) @db.Uuid
  dioceseId String            @db.Uuid
  parishId  String            @db.Uuid
  name      String
  capacity  Int?
  location  String?
  isActive  Boolean           @default(true)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  parish    Parish            @relation(fields: [parishId], references: [id], onDelete: Cascade)
  bookings  FacilityBooking[]
  events    Event[]

  @@index([dioceseId, parishId, isActive])
}

model FacilityBooking {
  id         String                @id @default(uuid()) @db.Uuid
  dioceseId  String                @db.Uuid
  parishId   String                @db.Uuid
  facilityId String                @db.Uuid
  eventId    String?               @db.Uuid
  title      String
  startAt    DateTime              @db.Timestamptz(6)
  endAt      DateTime              @db.Timestamptz(6)
  status     FacilityBookingStatus @default(CONFIRMED)
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt
  parish     Parish                @relation(fields: [parishId], references: [id], onDelete: Cascade)
  facility   Facility              @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  event      Event?                @relation(fields: [eventId], references: [id], onDelete: SetNull)
  // Note: the no_facility_overlap exclusion constraint is declared in Supabase SQL.

  @@index([dioceseId, parishId])
  @@index([facilityId, startAt])
}

// ── Phase 3: Communications (PA-8) ───────────────────────────────────────────

model Message {
  id              String             @id @default(uuid()) @db.Uuid
  dioceseId       String             @db.Uuid
  parishId        String             @db.Uuid
  channel         MessageChannel     @default(EMAIL)
  subject         String?
  body            String
  audienceType    AudienceType       @default(ALL_MEMBERS)
  audienceRefId   String?            @db.Uuid
  status          MessageStatus      @default(DRAFT)
  createdByUserId String?            @db.Uuid
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  parish          Parish             @relation(fields: [parishId], references: [id], onDelete: Cascade)
  recipients      MessageRecipient[]

  @@index([dioceseId, parishId, status])
}

model MessageRecipient {
  id                String          @id @default(uuid()) @db.Uuid
  dioceseId         String          @db.Uuid
  parishId          String          @db.Uuid
  messageId         String          @db.Uuid
  memberId          String          @db.Uuid
  channel           MessageChannel
  status            RecipientStatus @default(QUEUED)
  providerMessageId String?
  destination       String?
  error             String?
  sentAt            DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  parish            Parish          @relation(fields: [parishId], references: [id], onDelete: Cascade)
  message           Message         @relation(fields: [messageId], references: [id], onDelete: Cascade)
  member            Member          @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([messageId, memberId, channel])
  @@index([dioceseId, parishId, status])
  @@index([status])
}

model MessageTemplate {
  id        String         @id @default(uuid()) @db.Uuid
  dioceseId String         @db.Uuid
  parishId  String         @db.Uuid
  name      String
  channel   MessageChannel @default(EMAIL)
  subject   String?
  body      String
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  parish    Parish         @relation(fields: [parishId], references: [id], onDelete: Cascade)

  @@index([dioceseId, parishId])
}

model CommunicationPreference {
  id        String         @id @default(uuid()) @db.Uuid
  dioceseId String         @db.Uuid
  parishId  String         @db.Uuid
  memberId  String         @db.Uuid
  channel   MessageChannel
  optedOut  Boolean        @default(false)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  parish    Parish         @relation(fields: [parishId], references: [id], onDelete: Cascade)
  member    Member         @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([memberId, channel])
  @@index([dioceseId, parishId])
}

// ── Phase 3: Staff/volunteer (PA-6) ──────────────────────────────────────────

model VolunteerAssignment {
  id             String             @id @default(uuid()) @db.Uuid
  dioceseId      String             @db.Uuid
  parishId       String             @db.Uuid
  memberId       String             @db.Uuid
  scopeType      VolunteerScopeType
  programId      String?            @db.Uuid
  organizationId String?            @db.Uuid
  eventId        String?            @db.Uuid
  roleLabel      String
  isActive       Boolean            @default(true)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  parish         Parish             @relation(fields: [parishId], references: [id], onDelete: Cascade)
  member         Member             @relation(fields: [memberId], references: [id], onDelete: Cascade)
  program        Program?           @relation(fields: [programId], references: [id], onDelete: Cascade)
  organization   Organization?      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  event          Event?             @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([dioceseId, parishId])
  @@index([memberId])
}

// ── Phase 3: Member self-registration (MM-8) ─────────────────────────────────

model MemberRegistration {
  id               String             @id @default(uuid()) @db.Uuid
  dioceseId        String             @db.Uuid
  parishId         String             @db.Uuid
  firstName        String
  lastName         String
  email            String?
  phone            String?
  familyName       String?
  notes            String?
  approvalStatus   RegistrationStatus @default(PENDING)
  submittedAt      DateTime           @default(now())
  reviewedByUserId String?            @db.Uuid
  reviewedAt       DateTime?
  approvedMemberId String?            @unique @db.Uuid
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  parish           Parish             @relation(fields: [parishId], references: [id], onDelete: Cascade)
  approvedMember   Member?            @relation("MemberRegistrationApproved", fields: [approvedMemberId], references: [id], onDelete: SetNull)

  @@index([dioceseId, parishId, approvalStatus])
}


// ── R5 / M10 Finance models ──────────────────────────────────────────────────
// Multi-level ledgers: every finance row carries dioceseId (required) and
// optional parishId. Ledger owner is (ownerType, ownerId):
//   DIOCESE       → ownerId = dioceseId, parishId null
//   PARISH        → ownerId = parishId,  parishId set
//   ORGANIZATION  → ownerId = organizationId; parishId null (diocese org)
//                   or set (parish org)

model Fund {
  id         String          @id @default(uuid()) @db.Uuid
  dioceseId  String          @db.Uuid
  parishId   String?         @db.Uuid
  ownerType  LedgerOwnerType
  ownerId    String          @db.Uuid
  name       String
  isActive   Boolean         @default(true)
  createdAt  DateTime        @default(now())
  diocese    Diocese         @relation(fields: [dioceseId], references: [id], onDelete: Cascade)
  parish     Parish?         @relation(fields: [parishId], references: [id], onDelete: Cascade)
  accounts   Account[]
  campaigns  Campaign[]
  donationAllocations DonationAllocation[]
  givingCategories GivingCategory[]

  @@unique([ownerType, ownerId, name])
  @@index([dioceseId, ownerType, ownerId])
  @@index([parishId, ownerType, ownerId])
}

model Account {
  id         String          @id @default(uuid()) @db.Uuid
  dioceseId  String          @db.Uuid
  parishId   String?         @db.Uuid
  ownerType  LedgerOwnerType
  ownerId    String          @db.Uuid
  code       String
  name       String
  type       AccountType
  fundId     String?         @db.Uuid
  /// Presentation grouping for the Receipts & Payments report (expense side).
  /// Mirrors GivingCategory.section on the receipts side. Null → "Other payments".
  reportSection String?
  isActive   Boolean         @default(true)
  createdAt  DateTime        @default(now())
  diocese    Diocese         @relation(fields: [dioceseId], references: [id], onDelete: Cascade)
  parish     Parish?         @relation(fields: [parishId], references: [id], onDelete: Cascade)
  fund       Fund?           @relation(fields: [fundId], references: [id], onDelete: SetNull)
  journalLines JournalLine[]
  budgetLines  BudgetLine[]
  campaigns    Campaign[]    @relation("CampaignIncomeAccount")
  givingCategories GivingCategory[] @relation("GivingCategoryIncomeAccount")
  depositBatches   DonationBatch[]  @relation("DonationBatchDepositAccount")

  @@unique([ownerType, ownerId, code])
  @@index([dioceseId, ownerType, ownerId])
  @@index([parishId, ownerType, ownerId])
  @@index([fundId])
}

model AccountingPeriod {
  id               String          @id @default(uuid()) @db.Uuid
  dioceseId        String          @db.Uuid
  parishId         String?         @db.Uuid
  ownerType        LedgerOwnerType
  ownerId          String          @db.Uuid
  startDate        DateTime        @db.Date
  endDate          DateTime        @db.Date
  status           PeriodStatus    @default(OPEN)
  closedByUserId   String?         @db.Uuid
  closedAt         DateTime?
  reopenReason     String?
  reopenedByUserId String?         @db.Uuid
  reopenedAt       DateTime?
  createdAt        DateTime        @default(now())
  diocese          Diocese         @relation(fields: [dioceseId], references: [id], onDelete: Cascade)
  parish           Parish?         @relation(fields: [parishId], references: [id], onDelete: Cascade)
  closedBy         AppUser?        @relation("PeriodClosedBy", fields: [closedByUserId], references: [id], onDelete: SetNull)
  reopenedBy       AppUser?        @relation("PeriodReopenedBy", fields: [reopenedByUserId], references: [id], onDelete: SetNull)
  journalEntries   JournalEntry[]
  donations        Donation[]

  @@unique([ownerType, ownerId, startDate, endDate])
  @@index([dioceseId, ownerType, ownerId, status])
  @@index([parishId, ownerType, ownerId, status])
}

model JournalEntry {
  id              String            @id @default(uuid()) @db.Uuid
  dioceseId       String            @db.Uuid
  parishId        String?           @db.Uuid
  ownerType       LedgerOwnerType
  ownerId         String            @db.Uuid
  periodId        String            @db.Uuid
  entryDate       DateTime          @db.Date
  description     String
  reference       String?
  source          JournalSource     @default(MANUAL)
  status          JournalStatus     @default(DRAFT)
  cashImpact      Boolean           @default(true)
  reversesEntryId String?           @db.Uuid
  currency        String            @default("USD") @db.Char(3)
  createdByUserId String            @db.Uuid
  postedByUserId  String?           @db.Uuid
  postedAt        DateTime?
  createdAt       DateTime          @default(now())
  diocese         Diocese           @relation(fields: [dioceseId], references: [id], onDelete: Cascade)
  parish          Parish?           @relation(fields: [parishId], references: [id], onDelete: Cascade)
  period          AccountingPeriod  @relation(fields: [periodId], references: [id], onDelete: Restrict)
  createdBy       AppUser           @relation("JournalEntryCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  postedBy        AppUser?          @relation("JournalEntryPostedBy", fields: [postedByUserId], references: [id], onDelete: SetNull)
  reversesEntry   JournalEntry?     @relation("JournalReversal", fields: [reversesEntryId], references: [id], onDelete: SetNull)
  reversedBy      JournalEntry[]    @relation("JournalReversal")
  lines           JournalLine[]
  donations       Donation[]
  vendorBills     VendorBill[]
  payments        Payment[]
  donationBatches DonationBatch[]

  @@index([ownerType, ownerId, entryDate])
  @@index([periodId])
  @@index([dioceseId, status])
  @@index([parishId, status])
  @@index([reversesEntryId])
}

model JournalLine {
  id                 String              @id @default(uuid()) @db.Uuid
  journalEntryId     String              @db.Uuid
  accountId          String              @db.Uuid
  direction          JournalDirection
  amountCents        BigInt
  memo               String?
  journalEntry       JournalEntry        @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account            Account             @relation(fields: [accountId], references: [id], onDelete: Restrict)
  bankStatementLines BankStatementLine[]

  @@index([journalEntryId])
  @@index([accountId])
}

model ApprovalPolicy {
  id             String               @id @default(uuid()) @db.Uuid
  dioceseId      String               @db.Uuid
  parishId       String?              @db.Uuid
  ownerType      LedgerOwnerType
  ownerId        String               @db.Uuid
  entityKind     ApprovalEntityKind
  mode           ApprovalMode         @default(THRESHOLD_BASED)
  thresholdCents BigInt?
  approverRoles  Role[]
  minApprovals   Int                  @default(1)
  sensitiveKinds ApprovalEntityKind[] @default([])
  isActive       Boolean              @default(true)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
