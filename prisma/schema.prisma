  SMS
}

enum MessageStatus {
  DRAFT
  QUEUED
  PROCESSING
  SENT
  FAILED
}

enum RecipientStatus {
  QUEUED
  PROCESSING
  SENT
  FAILED
  SKIPPED
}

enum AudienceType {
  ALL_MEMBERS
  FAMILIES
  PROGRAM
  ORGANIZATION
  CUSTOM
}

enum RegistrationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum VolunteerScopeType {
  PROGRAM
  ORGANIZATION
  EVENT
}

enum ActorType {
  HUMAN
  SYSTEM
}

enum AuditOutcome {
