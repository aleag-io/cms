// ── R6 / M12: Outbound webhooks (IN-2) ───────────────────────────────────────

enum WebhookDeliveryStatus {
  PENDING
  PROCESSING
  DELIVERED
  FAILED // transient failure — will retry at nextAttemptAt
  DEAD // max attempts exhausted
}

/// Parish-managed endpoint registration. `secret` signs deliveries (HMAC) and is
/// therefore stored raw; RLS restricts SELECT to parish admins of the owning parish.
model WebhookSubscription {
  id              String            @id @default(uuid()) @db.Uuid
  dioceseId       String            @db.Uuid
  parishId        String            @db.Uuid
  name            String
  url             String
  secret          String
  /// Subscribed event types, validated against WEBHOOK_EVENTS (lib/webhooks/events.ts)
  events          String[]          @default([])
  isActive        Boolean           @default(true)
  createdByUserId String            @db.Uuid
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  diocese         Diocese           @relation(fields: [dioceseId], references: [id], onDelete: Cascade)
  parish          Parish            @relation(fields: [parishId], references: [id], onDelete: Cascade)
  createdBy       AppUser           @relation("WebhookSubscriptionCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  deliveries      WebhookDelivery[]

  @@index([dioceseId, parishId, isActive])
}

/// Transactional outbox: domain routes insert one row in the same withTenant
/// transaction as the domain write; the privileged worker fans out + delivers.
model WebhookEvent {
  id          String            @id @default(uuid()) @db.Uuid
  dioceseId   String            @db.Uuid
  parishId    String            @db.Uuid
  type        String
  entityId    String?           @db.Uuid
  payload     Json
  createdAt   DateTime          @default(now())
  processedAt DateTime?
  diocese     Diocese           @relation(fields: [dioceseId], references: [id], onDelete: Cascade)
  parish      Parish            @relation(fields: [parishId], references: [id], onDelete: Cascade)
  deliveries  WebhookDelivery[]

  @@index([processedAt, createdAt])
  @@index([dioceseId, parishId, type])
}

model WebhookDelivery {
  id             String                @id @default(uuid()) @db.Uuid
  dioceseId      String                @db.Uuid
  parishId       String                @db.Uuid
  subscriptionId String                @db.Uuid
  eventId        String                @db.Uuid
  /// Denormalized from WebhookEvent.type for the delivery-log UI
  eventType      String
  status         WebhookDeliveryStatus @default(PENDING)
  attemptCount   Int                   @default(0)
  nextAttemptAt  DateTime              @default(now())
  lastAttemptAt  DateTime?
  responseStatus Int?
  lastError      String?
  deliveredAt    DateTime?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  diocese        Diocese               @relation(fields: [dioceseId], references: [id], onDelete: Cascade)
  parish         Parish                @relation(fields: [parishId], references: [id], onDelete: Cascade)
  subscription   WebhookSubscription   @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  event          WebhookEvent          @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([subscriptionId, eventId])
  @@index([status, nextAttemptAt])
  @@index([dioceseId, parishId, createdAt])
}
