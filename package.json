{
  "name": "cms",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "24.x",
    "npm": ">=10"
  },
  "packageManager": "npm@11.17.0",
  "scripts": {
    "dev": "next dev --webpack",
    "build": "prisma generate && npm run db:migrate:all && next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "prisma generate && tsc --noEmit",
    "api-docs:lint": "redocly lint docs/openapi.yaml",
    "api-docs:build": "redocly build-docs docs/openapi.yaml -o public/api-docs/index.html",
    "api-docs:ci": "npm run api-docs:lint && npm run api-docs:build",
    "prebuild": "npm run api-docs:build",
    "postinstall": "prisma generate",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:rls": "vitest run --project rls",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:coverage": "vitest run --coverage",
    "ci": "npm run typecheck && npm run lint && npm run test:unit && npm run test:integration && npm run test:rls && npm run test:e2e",
    "db:apply-rls": "node scripts/apply-sql.js supabase/migrations",
    "db:apply-rls:remote": "node scripts/apply-sql.js supabase/migrations",
    "db:apply-ci-shims": "node scripts/apply-sql.js scripts/ci-auth-shims.sql",
    "db:migrate:all": "node scripts/db-migrate-all.js",
    "db:rebuild": "npm run db:migrate:all",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "db:migrate": "npm run prisma:migrate:dev && npm run db:apply-rls",
    "db:reset": "prisma migrate reset --force && npm run prisma:generate && npm run db:apply-rls",
    "db:seed": "tsx prisma/seed.ts",
    "db:ensure-local-admin": "node scripts/ensure-local-admin.js",
    "supabase:init": "supabase init",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:status": "supabase status",
    "supabase:reset": "supabase db reset"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@hookform/resolvers": "^5.4.0",
    "@phosphor-icons/react": "^2.1.10",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "@tanstack/react-query": "^5.101.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "next": "16.2.9",
    "next-themes": "^0.4.6",
    "pg": "^8.22.0",
    "radix-ui": "^1.6.0",
    "react": "19.2.4",
    "react-day-picker": "^10.0.1",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.80.0",
    "react-resizable-panels": "^4.11.2",
    "recharts": "^3.8.0",
    "shadcn": "^4.11.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@redocly/cli": "^2.36.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "jsdom": "^29.1.1",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.23.0",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.9",
    "wait-on": "^9.0.10"
  },
  "allowScripts": {
    "sharp@0.34.5": true,
    "unrs-resolver@1.12.2": true,
    "@prisma/client@6.19.3": true,
    "prisma@7.8.0": true,
    "@prisma/engines@7.8.0": true
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
